{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qintopia.local/schemas/pricing-case.schema.json",
  "title": "QinTopia real pricing fact",
  "type": "object",
  "additionalProperties": false,
  "required": ["caseId", "anonymizedOrderRef", "businessExplanation", "businessPlan", "scenarioTags", "propertyTimeZone", "currency", "inventoryUnitKind", "arrivalDate", "departureDate", "departureCharged", "priceInputs", "coverageSet", "amendments", "rounding", "expected"],
  "properties": {
    "caseId": { "type": "string", "minLength": 1 },
    "anonymizedOrderRef": { "type": "string", "minLength": 1 },
    "businessExplanation": { "type": "string", "minLength": 1 },
    "businessPlan": { "enum": ["TRANSIENT", "WEEKLY", "MONTHLY", "CUSTOM", "FIXED_TERM", "ROLLING", "FREE"] },
    "scenarioTags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["BASELINE", "SHORTEN", "EXTEND", "MOVE", "CROSS_MONTH", "PARTIAL_MEMBER_COVERAGE", "MANUAL_ADJUSTMENT", "BOUNDARY"] }
    },
    "propertyTimeZone": { "type": "string", "minLength": 1 },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "inventoryUnitKind": { "enum": ["ROOM", "BED"] },
    "arrivalDate": { "type": "string", "format": "date" },
    "departureDate": { "type": "string", "format": "date" },
    "departureCharged": { "type": "boolean" },
    "priceInputs": { "type": "object", "additionalProperties": true },
    "coverageSet": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["serviceDate", "inventoryUnitReference", "unitKind"],
        "properties": {
          "serviceDate": { "type": "string", "format": "date" },
          "inventoryUnitReference": { "type": "string", "minLength": 1 },
          "unitKind": { "enum": ["ROOM_NIGHT", "BED_NIGHT"] }
        }
      }
    },
    "amendments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence", "amendmentType", "requestedAt", "input"],
        "properties": {
          "sequence": { "type": "integer", "minimum": 2 },
          "amendmentType": { "enum": ["SHORTEN_STAY", "EXTEND_STAY", "MOVE_UNIT", "REPRICE_ORDER"] },
          "requestedAt": { "type": "string", "format": "date-time" },
          "input": { "type": "object", "minProperties": 1, "additionalProperties": true }
        }
      }
    },
    "rounding": { "type": "object", "additionalProperties": true },
    "boundaryEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["boundaryName", "comparisonCaseId", "observedBehaviorChange"],
      "properties": {
        "boundaryName": { "type": "string", "minLength": 1 },
        "comparisonCaseId": { "type": "string", "minLength": 1 },
        "observedBehaviorChange": { "type": "string", "minLength": 1 }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pricingRevisions", "cashLines", "cashRemainderMinor", "currentContractAmountMinor"],
      "properties": {
        "pricingRevisions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["revisionNo", "amendmentType", "pricingPolicyVersionReference", "arrivalDate", "departureDate", "coverageSet", "cashLines", "manualAdjustmentMinor", "cashRemainderMinor", "currentContractAmountMinor", "roundingEvidence"],
            "properties": {
              "revisionNo": { "type": "integer", "minimum": 1 },
              "amendmentType": { "enum": ["CREATE_ORDER", "SHORTEN_STAY", "EXTEND_STAY", "MOVE_UNIT", "REPRICE_ORDER"] },
              "pricingPolicyVersionReference": { "type": "string", "minLength": 1 },
              "arrivalDate": { "type": "string", "format": "date" },
              "departureDate": { "type": "string", "format": "date" },
              "coverageSet": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["serviceDate", "inventoryUnitReference", "unitKind"],
                  "properties": {
                    "serviceDate": { "type": "string", "format": "date" },
                    "inventoryUnitReference": { "type": "string", "minLength": 1 },
                    "unitKind": { "enum": ["ROOM_NIGHT", "BED_NIGHT"] }
                  }
                }
              },
              "cashLines": { "type": "array", "items": { "type": "object", "minProperties": 1, "additionalProperties": true } },
              "manualAdjustmentMinor": { "type": "integer" },
              "cashRemainderMinor": { "type": "integer" },
              "currentContractAmountMinor": { "type": "integer" },
              "roundingEvidence": { "type": "object", "minProperties": 1, "additionalProperties": true }
            }
          }
        },
        "cashLines": { "type": "array", "items": { "type": "object", "minProperties": 1, "additionalProperties": true } },
        "cashRemainderMinor": { "type": "integer" },
        "currentContractAmountMinor": { "type": "integer" }
      }
    }
  }
}
